{
  "name": "@queue/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@queue/config": "workspace:*",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
