# QUEUE/2 database connections
#
# Keep development, preview/test and production on separate Neon branches.
# Never reuse unsanitized production data in development or preview/test.
# These database URLs are server-only. Do not create public NEXT_PUBLIC_* copies.
#
# Use a pooled, least-privileged app runtime Neon connection for local app requests.
DATABASE_URL="postgresql://queue2_app_runtime:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Use a direct owner/migrator Neon connection for Drizzle migrations and schema checks.
DIRECT_DATABASE_URL="postgresql://queue2_migrator:password@ep-example.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Use an isolated Neon preview/test branch or local Postgres database for integration tests.
TEST_DATABASE_URL="postgresql://queue2_migrator:password@ep-example-test.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Better Auth runtime
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# Public canonical origin used by metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Local/dev only: set to false when testing auth flows without email delivery.
# Production always requires email verification regardless of this value.
AUTH_REQUIRE_EMAIL_VERIFICATION="true"
# Production is enabled by default. In local/dev, set this to true only when
# you want the server to call Have I Been Pwned during manual auth testing.
# The full password and full hash are never sent to the provider.
AUTH_PASSWORD_BREACH_CHECK="true"

# Transactional auth email
RESEND_API_KEY="re_..."
EMAIL_FROM="QUEUE/2 <auth@example.com>"

# Server-only game catalog sync
# RAWG_API_KEY stays on the server for catalog jobs and adapters only.
RAWG_API_KEY="rawg_..."
# Vercel Cron sends this as Authorization: Bearer $CRON_SECRET.
CRON_SECRET="replace-with-a-strong-random-cron-secret"
# Optional local/debug override for `pnpm catalog:refresh`.
CATALOG_REFRESH_URL="http://localhost:3000/api/jobs/catalog/refresh"

# Match Live web push notifications
VAPID_PUBLIC_KEY="replace-with-generated-vapid-public-key"
# Server-only. Browser code receives VAPID_PUBLIC_KEY through the authenticated
# Discovery push endpoint; never expose this value through NEXT_PUBLIC_*.
VAPID_PRIVATE_KEY="replace-with-generated-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"

# Optional server-only localization draft providers.
# QUEUE/2 curated copy can ship without these. Provider output is draft/review
# input only and must pass the localization checklist before publication.
DEEPL_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_TRANSLATE_API_KEY=""
AZURE_TRANSLATOR_KEY=""

# Phase 1 Playwright gate and Phase 03.1 Discovery browser evidence
#
# Point at an isolated test deployment. Set E2E_START_SERVER=1 only when the
# local app environment is fully configured and Playwright should start `pnpm dev`.
E2E_BASE_URL="http://127.0.0.1:3000"
E2E_START_SERVER="0"

# Verified, clean no-duo accounts for the serial pairing and third-member flow.
E2E_FLOW_OWNER_EMAIL="flow-owner@example.com"
E2E_FLOW_OWNER_PASSWORD="replace-with-test-password"
E2E_FLOW_PARTNER_EMAIL="flow-partner@example.com"
E2E_FLOW_PARTNER_PASSWORD="replace-with-test-password"
E2E_FLOW_THIRD_EMAIL="flow-third@example.com"
E2E_FLOW_THIRD_PASSWORD="replace-with-test-password"

# Verified no-duo and named-duo fixtures for accessibility and route isolation.
E2E_PAIRING_USER_EMAIL="pairing-a11y@example.com"
E2E_PAIRING_USER_PASSWORD="replace-with-test-password"
# Ready duo fixtures must be verified users in the same duo with seeded
# Discovery/catalog data. Partner credentials are required for reciprocal match
# evidence; other-duo credentials are required for isolation checks.
E2E_READY_USER_EMAIL="ready-duo@example.com"
E2E_READY_USER_PASSWORD="replace-with-test-password"
E2E_READY_PARTNER_EMAIL="ready-duo-partner@example.com"
E2E_READY_PARTNER_PASSWORD="replace-with-test-password"
E2E_READY_DUO_NAME="Dupla pronta E2E"
E2E_OTHER_DUO_USER_EMAIL="other-duo@example.com"
E2E_OTHER_DUO_USER_PASSWORD="replace-with-test-password"
E2E_OTHER_DUO_NAME="Outra dupla E2E"
# Query must return at least one eligible coop card for /app/descobrir search.
E2E_PHASE3_DISCOVERY_QUERY="it takes two"
# Phase 03.3 production-like performance gates. The catalog query must return
# visible /app/catalogo results; the slug must point to an existing game detail.
E2E_PHASE3_3_CATALOG_QUERY="it takes two"
E2E_PHASE3_3_GAME_SLUG="it-takes-two"
