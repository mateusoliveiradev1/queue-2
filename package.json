{
  "name": "queue2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.5.1"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint --config packages/config/eslint/index.js apps/web packages/db packages/ui scripts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "node scripts/with-env-local.mjs turbo run test:integration",
    "catalog:sync": "node --conditions react-server --experimental-strip-types scripts/catalog-sync.ts",
    "catalog:refresh": "node --experimental-strip-types scripts/catalog-refresh.ts",
    "catalog:seed-curation": "node --conditions react-server --experimental-strip-types scripts/catalog-curation-seed.ts",
    "check:architecture": "turbo run check:architecture",
    "check:secrets": "node scripts/check-secrets.mjs",
    "audit:dependencies": "pnpm audit --prod --audit-level high",
    "phase:1:gate": "node scripts/phase-1-gate.mjs",
    "phase:03.3:gate": "node scripts/phase-03-3-gate.mjs",
    "verify": "pnpm check:secrets && pnpm lint && node scripts/with-env-local.mjs turbo run check:architecture typecheck test test:integration"
  },
  "devDependencies": {
    "eslint": "10.4.1",
    "turbo": "2.9.16",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1"
  }
}
