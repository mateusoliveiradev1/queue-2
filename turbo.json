{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_BETTER_AUTH_URL",
        "BETTER_AUTH_TRUSTED_ORIGINS",
        "AUTH_REQUIRE_EMAIL_VERIFICATION",
        "AUTH_PASSWORD_BREACH_CHECK",
        "CRON_SECRET",
        "RAWG_API_KEY",
        "RESEND_API_KEY",
        "EMAIL_FROM"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"],
      "cache": false,
      "env": ["TEST_DATABASE_URL"],
      "outputs": ["coverage/**"]
    },
    "check:architecture": {
      "dependsOn": ["^check:architecture"],
      "outputs": []
    }
  }
}
